# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (local or Vercel Postgres / Neon / Supabase)
DATABASE_URL="postgresql://postgres:password@localhost:5432/safecircle"

# ── Session ───────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -base64 32
SESSION_SECRET="change-me-please-use-32-char-min!!"

# ── Twilio Verify (SMS OTP) ───────────────────────────────────────────────────
# Leave blank in dev to use bypass mode (code: 123456)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_VERIFY_SERVICE_SID=""

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# ── Alert Ingestion Secret ────────────────────────────────────────────────────
# Shared secret for POST /api/alerts/ingest (leave blank to allow all in dev)
ALERT_INGEST_SECRET=""
